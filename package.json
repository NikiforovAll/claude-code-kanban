{
  "name": "claude-code-kanban",
  "version": "3.1.0",
  "description": "A web-based Kanban board for viewing Claude Code tasks with agent teams support",
  "main": "server.js",
  "bin": {
    "claude-code-kanban": "./server.js"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --test test/contracts.test.js",
    "test:hooks": "bash tests/test-agent-spy.sh",
    "validate:schemas": "node test/validate-live-schemas.js",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NikiforovAll/claude-code-kanban.git"
  },
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "tasks",
    "todo",
    "kanban",
    "viewer",
    "agent-teams"
  ],
  "author": "NikiforovAll",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/NikiforovAll/claude-code-kanban/issues"
  },
  "homepage": "https://github.com/NikiforovAll/claude-code-kanban#readme",
  "dependencies": {
    "chokidar": "^3.5.3",
    "express": "^4.18.2",
    "open": "^11.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "server.js",
    "install.js",
    "plugin/**/*",
    "lib/**/*",
    "public/**/*"
  ],
  "devDependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "husky": "^9.1.7"
  }
}
